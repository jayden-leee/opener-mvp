# =============================================
# 오프너(Opener) — 환경변수 완전 체크리스트
# cp .env.example .env  →  실제 값 입력 후 실행
# .env는 절대 Git에 커밋하지 마세요!
# =============================================

# ┌─────────────────────────────────────────┐
# │  REQUIRED (필수 — 없으면 앱 실행 불가)  │
# └─────────────────────────────────────────┘

# LLM 프로바이더 중 하나는 반드시 필요
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 기본 모델 설정
DEFAULT_LLM_PROVIDER=openai
DEFAULT_MODEL=gpt-4o

# ┌─────────────────────────────────────────┐
# │  RECOMMENDED (권장 — 핵심 기능용)       │
# └─────────────────────────────────────────┘

# Tavily AI 검색 (3단계 바이어 발굴 필수)
# 발급: https://app.tavily.com  (월 1,000회 무료)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase DB (5단계 데이터 저장)
# 발급: https://supabase.com  (무료 티어 500MB)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxx

# ┌─────────────────────────────────────────┐
# │  OPTIONAL (선택)                        │
# └─────────────────────────────────────────┘

# Anthropic Claude (OpenAI 대신 사용 시)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 번역 보조 API
GOOGLE_TRANSLATE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPL_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:fx

# 관세청 Open API
CUSTOMS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxx
CUSTOMS_API_URL=https://unipass.customs.go.kr/csp/info

# 코트라 Open API
KOTRA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxx

# ┌─────────────────────────────────────────┐
# │  APP CONFIG                             │
# └─────────────────────────────────────────┘
APP_ENV=production          # development | production
DEBUG=false
LOG_LEVEL=INFO
